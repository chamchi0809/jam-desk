{
  "name": "jam-desk",
  "displayName": "%jamDesk.displayName%",
  "description": "%jamDesk.description%",
  "version": "0.3.0",
  "publisher": "chamchi",
  "repository": {
    "url": "https://github.com/chamchi0809/jam-desk"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Notebooks",
    "Other"
  ],
  "keywords": [
    "canvas",
    "infinite canvas",
    "whiteboard",
    "spatial",
    "mind map",
    "jam desk"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "icon": "media/icon.png",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "jamDesk.open",
        "title": "%jamDesk.command.open.title%",
        "category": "Jam Desk",
        "icon": {
          "light": "media/open-canvas-light.svg",
          "dark": "media/open-canvas-dark.svg"
        }
      },
      {
        "command": "jamDesk.addNote",
        "title": "%jamDesk.command.addNote.title%",
        "category": "Jam Desk",
        "icon": "$(note)"
      },
      {
        "command": "jamDesk.addTerminal",
        "title": "%jamDesk.command.addTerminal.title%",
        "category": "Jam Desk",
        "icon": "$(terminal)"
      },
      {
        "command": "jamDesk.addFile",
        "title": "%jamDesk.command.addFile.title%",
        "category": "Jam Desk",
        "icon": "$(file-add)"
      },
      {
        "command": "jamDesk.addCurrentFile",
        "title": "%jamDesk.command.addCurrentFile.title%",
        "category": "Jam Desk",
        "icon": "$(file-symlink-file)"
      },
      {
        "command": "jamDesk.fitToScreen",
        "title": "%jamDesk.command.fitToScreen.title%",
        "category": "Jam Desk",
        "icon": "$(screen-full)"
      },
      {
        "command": "jamDesk.autoLayout",
        "title": "%jamDesk.command.autoLayout.title%",
        "category": "Jam Desk",
        "icon": "$(layout-centered)"
      },
      {
        "command": "jamDesk.resetView",
        "title": "%jamDesk.command.resetView.title%",
        "category": "Jam Desk"
      },
      {
        "command": "jamDesk.export",
        "title": "%jamDesk.command.export.title%",
        "category": "Jam Desk"
      },
      {
        "command": "jamDesk.import",
        "title": "%jamDesk.command.import.title%",
        "category": "Jam Desk"
      },
      {
        "command": "jamDesk.clear",
        "title": "%jamDesk.command.clear.title%",
        "category": "Jam Desk"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "jamDesk.addCurrentFile",
          "when": "jamDesk.active && editorIsOpen",
          "group": "navigation@9"
        },
        {
          "command": "jamDesk.open",
          "when": "!jamDesk.active",
          "group": "navigation@10"
        }
      ],
      "commandPalette": [
        {
          "command": "jamDesk.addNote",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.addTerminal",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.addFile",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.fitToScreen",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.autoLayout",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.resetView",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.export",
          "when": "jamDesk.active"
        },
        {
          "command": "jamDesk.clear",
          "when": "jamDesk.active"
        }
      ]
    },
    "configuration": {
      "title": "Jam Desk",
      "properties": {
        "jamDesk.gridStyle": {
          "type": "string",
          "enum": [
            "dots",
            "lines",
            "none"
          ],
          "default": "dots",
          "description": "%jamDesk.config.gridStyle.description%"
        },
        "jamDesk.snapToGrid": {
          "type": "boolean",
          "default": true,
          "description": "%jamDesk.config.snapToGrid.description%"
        },
        "jamDesk.zoomSpeed": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 3,
          "description": "%jamDesk.config.zoomSpeed.description%"
        },
        "jamDesk.showMinimap": {
          "type": "boolean",
          "default": true,
          "description": "%jamDesk.config.showMinimap.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@tabler/icons": "^3.44.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
